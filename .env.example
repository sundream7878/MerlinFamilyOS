# --- [Supabase Configuration] ---
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- [Hub Security] ---
# JWT 인증용 시크릿 (강력한 문자열 권장)
JWT_SECRET="merlin-family-secure-jwt-secret-key"
JWT_EXPIRES_IN="7d"

# 허브 관리자용 마스터 키 (새 앱 등록 등)
HUB_ADMIN_API_KEY="merlin-hub-admin-master-key"

# --- [Email Engine (Resend)] ---
# 모든 패밀리 앱의 메일 발송을 위한 통합 리센드 키
RESEND_API_KEY="re_123456789"
# 발신자 주소 (예: Merlin Family <no-reply@merlinfamily.os>)
MAIL_FROM="Merlin Family <onboarding@resend.dev>"

# --- [Cross-Origin Resource Sharing] ---
# 허용할 도메인 목록 (쉼표로 구분)
CORS_WHITELIST="http://localhost:3000,http://localhost:5173,http://aggro-filter.merlin.os"

# --- [AI & Others] ---
GEMINI_API_KEY="your-gemini-key"
APP_URL="http://localhost:3001"
